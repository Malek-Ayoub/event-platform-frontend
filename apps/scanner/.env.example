# API origins only — OpenAPI paths already include /api/...
VITE_API_PUBLIC_URL=http://localhost:8000
VITE_API_TENANT_URL=http://localhost:8000
VITE_API_ADMIN_URL=http://localhost:8000
VITE_TENANCY_BASE_DOMAIN=localhost
VITE_TENANT_SLUG=pilot

# Error monitoring (Sentry). Leave empty locally; fill with a real browser DSN when a production account is available.
# Empty / unset skips Sentry.init entirely (no network calls).
VITE_SENTRY_DSN=
