# API origins only — OpenAPI paths already include /api/...
NEXT_PUBLIC_API_PUBLIC_URL=http://localhost:8000
NEXT_PUBLIC_API_TENANT_URL=http://localhost:8000
NEXT_PUBLIC_API_ADMIN_URL=http://localhost:8000
NEXT_PUBLIC_TENANCY_BASE_DOMAIN=localhost

# Error monitoring (Sentry). Leave empty locally; fill with a real browser DSN when a production account is available.
# Empty / unset disables Sentry entirely (no network calls).
NEXT_PUBLIC_SENTRY_DSN=
