# API origins only — OpenAPI paths already include /api/...
# For local tenant-scoped public APIs, point at the venue subdomain host.
NEXT_PUBLIC_API_PUBLIC_URL=http://pilot.localhost:8000
NEXT_PUBLIC_API_TENANT_URL=http://pilot.localhost:8000
NEXT_PUBLIC_API_ADMIN_URL=http://localhost:8000

# Used when API_* URLs are omitted: builds http://{slug}.localhost:8000
NEXT_PUBLIC_TENANT_SLUG=pilot
NEXT_PUBLIC_TENANCY_BASE_DOMAIN=localhost
