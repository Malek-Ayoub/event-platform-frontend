{
  "name": "@event-platform/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "sync:openapi": "node ./scripts/sync-openapi.mjs",
    "generate:api": "node ./scripts/generate-api.mjs",
    "generate:api:check": "pnpm generate:api && git diff --exit-code -- src/core/generated openapi/filtered",
    "prebuild": "pnpm generate:api",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@event-platform/auth": "workspace:*",
    "axios": "^1.7.9"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@event-platform/config": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "eslint": "^9.17.0",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.5.2",
    "react": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
